                if lowIdx1 == 46 then ret46 else
                if lowIdx1 == 47 then ret47 else
                if lowIdx1 == 48 then ret48 else
                if lowIdx1 == 49 then ret49 else
                ret50
            ) + eps * lowIdx1
        )
    else Double.NaN;


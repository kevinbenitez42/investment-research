                if shortCountIdx == 40 then ret40 else
                if shortCountIdx == 41 then ret41 else
                if shortCountIdx == 42 then ret42 else
                if shortCountIdx == 43 then ret43 else
                if shortCountIdx == 44 then ret44 else
                if shortCountIdx == 45 then ret45 else
                if shortCountIdx == 46 then ret46 else
                if shortCountIdx == 47 then ret47 else
                if shortCountIdx == 48 then ret48 else
                if shortCountIdx == 49 then ret49 else
                ret50
            ) >= shortVarReturn
            then 1
            else 0
        )
    else 0;

def shortCvarReturn =
    if enoughHistory and shortTailCount > 0
    then shortTailSum / shortTailCount
    else Double.NaN;

def longVarPrice =
    if !IsNaN(sessionOpen)
    then sessionOpen * (1 + longVarReturn)
    else Double.NaN;

def shortVarPrice =
    if !IsNaN(sessionOpen)
    then sessionOpen * (1 + shortVarReturn)
    else Double.NaN;

def longCvarPrice =
    if !IsNaN(sessionOpen)
    then sessionOpen * (1 + longCvarReturn)
    else Double.NaN;

def shortCvarPrice =
    if !IsNaN(sessionOpen)
    then sessionOpen * (1 + shortCvarReturn)
    else Double.NaN;

def orH =
    if openingBell
    then h
    else if orActive and h > orH[1]
    then h
    else orH[1];

def orL =
    if openingBell
    then l
    else if orActive and l < orL[1]
    then l
    else orL[1];

def orMeanH =
    if openingBell
    then h
    else if orMeanActive and h > orMeanH[1]
    then h
    else orMeanH[1];

def orMeanL =
    if openingBell
    then l
    else if orMeanActive and l < orMeanL[1]
    then l
    else orMeanL[1];

def orMean =
    Round(((orMeanH + orMeanL) / 2) / TickSize(), 0) * TickSize();

plot LongVaR95 =
    if showVaRCVaR and enoughHistory and rth
    then longVarPrice
    else Double.NaN;
LongVaR95.SetDefaultColor(Color.RED);
LongVaR95.SetLineWeight(2);
LongVaR95.SetStyle(Curve.SHORT_DASH);

plot LongCVaR95 =
    if showVaRCVaR and enoughHistory and rth
    then longCvarPrice
    else Double.NaN;
LongCVaR95.SetDefaultColor(Color.RED);
LongCVaR95.SetLineWeight(2);

plot ShortVaR95 =
    if showVaRCVaR and enoughHistory and rth
    then shortVarPrice
    else Double.NaN;
ShortVaR95.SetDefaultColor(Color.RED);
ShortVaR95.SetLineWeight(2);
ShortVaR95.SetStyle(Curve.SHORT_DASH);

plot ShortCVaR95 =
    if showVaRCVaR and enoughHistory and rth
    then shortCvarPrice
    else Double.NaN;
ShortCVaR95.SetDefaultColor(Color.RED);
ShortCVaR95.SetLineWeight(2);

plot ORHighLine =
    if showOpeningRange and !orActive and rth
    then orH
    else Double.NaN;
ORHighLine.SetStyle(Curve.LONG_DASH);
ORHighLine.SetLineWeight(3);
ORHighLine.SetDefaultColor(Color.YELLOW);

plot ORLowLine =
    if showOpeningRange and !orActive and rth
    then orL
    else Double.NaN;
ORLowLine.SetStyle(Curve.LONG_DASH);
ORLowLine.SetLineWeight(3);
ORLowLine.SetDefaultColor(Color.YELLOW);

plot ORMeanLine =
    if showOpeningRange and !orMeanActive and rth
    then orMean
    else Double.NaN;
ORMeanLine.SetStyle(Curve.LONG_DASH);
ORMeanLine.SetLineWeight(3);
ORMeanLine.SetDefaultColor(Color.YELLOW);
